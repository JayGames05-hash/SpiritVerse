# PostgreSQL settings for this app
# When deploying to Railway, use the INTERNAL URL (faster, recommended):
# DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway
#
# Or use the PUBLIC URL if connecting from outside Railway:
# DATABASE_URL=postgresql://postgres:PASSWORD@yamanote.proxy.rlwy.net:23564/railway
#
# For local development with a remote Railway database:
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/DATABASE
